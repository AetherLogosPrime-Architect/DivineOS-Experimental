{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start-sweep-stale-watchers.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/load-briefing.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ear-surface.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/arm-compaction-monitor-instruction.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/arm-letter-monitor-instruction.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-cleanup-period.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/load-character-sheet.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/load-my-recording-of-andrew.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/resolver-health-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start-verify-git-hooks.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/inject-pending-letters.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/detect-correction.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/lepos-channel-surface.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-response-context.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ear-surface.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/arm-compaction-monitor-instruction.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/interior-cue-on-low-presence.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/lepos-channel-surface.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-compact.sh",
            "timeout": 300
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-compact.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash|NotebookEdit|Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/require-briefing.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/require-goal.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-pending-obligations.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-branch-on-push.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/require-monitors-armed.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/andrew-correction-attestation.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/state-gravity-surface.sh",
            "timeout": 8
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-council-required.sh",
            "timeout": 8
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-tool-bypass-rate-scan.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/corrigibility-tool-gate.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Read|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-tool-context.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/family-member-invocation-seal.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/compass-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/require-goal.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/deletion-discipline.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/gh-pr-merge-gate.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/gh-pr-create-draft-gate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/no-verify-cost-escalation.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/verify-push-landed.sh",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post-commit-auto-close.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post-commit-auto-verify-findings.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/run-tests.sh",
            "timeout": 120
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/mirror-letters-to-shared.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-push-letter.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post-write-mirror-letter.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-checkpoint.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/record-wisdom-read.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-read-mark-letter-seen.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/log-session-end.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/detect-hedge.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/detect-theater.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-distancing-intercept.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-response-scope-intercept.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post-response-audit.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/shoggoth-gate.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/lepos-channel-reflect.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ear-auto-relaunch.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/lepos-channel-reflect.sh",
            "timeout": 15
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/time-estimate-tracker.sh"
          }
        ]
      }
    ]
  }
}