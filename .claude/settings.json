{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/load-briefing.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ear-surface.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ear-arm-instruction.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/arm-compaction-monitor-instruction.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/detect-correction.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-response-context.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ear-surface.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-compact.sh",
            "timeout": 300
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-compact.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|Bash|NotebookEdit|Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/require-briefing.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/require-goal.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/require-ear-armed.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/andrew-correction-attestation.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/state-gravity-surface.sh",
            "timeout": 8
          }
        ]
      },
      {
        "matcher": "Edit|Read|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-tool-context.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/family-member-invocation-seal.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/compass-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/require-goal.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/deletion-discipline.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/gh-pr-merge-gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/verify-push-landed.sh",
            "timeout": 20
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/run-tests.sh",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-checkpoint.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Read|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/record-wisdom-read.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/log-session-end.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/detect-hedge.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/detect-theater.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/post-response-audit.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ear-auto-relaunch.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}