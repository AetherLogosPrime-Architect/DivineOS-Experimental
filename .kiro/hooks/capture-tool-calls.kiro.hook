{
  "name": "Capture tool calls and results",
  "version": "1.0.0",
  "description": "Automatically log tool invocations and results to the DivineOS ledger",
  "when": {
    "type": "postToolUse",
    "toolTypes": ["*"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Tool execution completed. Events are being captured automatically by the IDE integration layer."
  }
}
