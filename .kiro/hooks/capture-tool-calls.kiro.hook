{
  "name": "Capture tool calls and results",
  "version": "1.0.0",
  "description": "Automatically log tool invocations and results to the DivineOS ledger",
  "when": {
    "type": "postToolUse",
    "toolTypes": ["*"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A tool just executed. Emit a TOOL_RESULT event to capture it. Use: divineos emit TOOL_RESULT --tool-name \"<tool-name>\" --tool-use-id \"tool-use-<timestamp>\" --result \"<brief-result>\" --duration-ms <ms>"
  }
}
