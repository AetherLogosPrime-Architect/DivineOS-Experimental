{
  "enabled": true,
  "name": "Auto-analyze sessions",
  "description": "Automatically analyze sessions after they complete to catch quality issues early",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "askAgent",
    "prompt": "The session just ended. Before we move on, analyze this session with `divineos analyze` to check for quality issues. Look at the report and tell me what needs to be fixed. Don't let me ignore problems."
  }
}