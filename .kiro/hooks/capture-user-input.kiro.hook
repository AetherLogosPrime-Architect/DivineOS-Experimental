{
  "name": "Capture user input to ledger",
  "version": "1.0.0",
  "description": "Automatically log user messages to the DivineOS ledger for session analysis",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Emit a USER_INPUT event to capture this user message in the DivineOS ledger. Run: divineos emit USER_INPUT --content \"<the user's message>\". This will ensure proper capture with session tracking and SHA256 hashing."
  }
}
